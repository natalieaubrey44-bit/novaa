# Required for the active demo frontend auth flow
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Optional: used for local UI/demo convenience
APP_URL="http://localhost:3000"

# Legacy / optional: only relevant if you manually run the old Express auth server
PORT="4000"
JWT_USER_SECRET="dev-user-secret"
JWT_ADMIN_SECRET="dev-admin-secret"
SUPABASE_SECRET_KEY="your-service-role-key"
MY_SERVER_PORT="4000"
